{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ASF Automation AI Review",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "ai_review_version",
    "project",
    "step",
    "reviewer",
    "verdict",
    "status",
    "risk_level",
    "scope_check",
    "tests_check",
    "gate_check",
    "deterministic_gate_status",
    "findings",
    "warnings",
    "evidence",
    "recommendation"
  ],
  "properties": {
    "ai_review_version": {
      "type": "string"
    },
    "project": {
      "type": "string"
    },
    "step": {
      "type": "string"
    },
    "reviewer": {
      "type": "string"
    },
    "verdict": {
      "type": "string",
      "enum": [
        "PASS",
        "PASS_WITH_WARNINGS",
        "FAIL",
        "BLOCKED"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "PASS",
        "PASS_WITH_WARNINGS",
        "FAIL",
        "BLOCKED"
      ]
    },
    "risk_level": {
      "type": "string",
      "enum": [
        "L0",
        "L1",
        "L2",
        "L3",
        "L4"
      ]
    },
    "scope_check": {
      "type": "string",
      "enum": [
        "PASS",
        "PASS_WITH_WARNINGS",
        "FAIL",
        "BLOCKED"
      ]
    },
    "tests_check": {
      "type": "string",
      "enum": [
        "PASS",
        "PASS_WITH_WARNINGS",
        "FAIL",
        "BLOCKED"
      ]
    },
    "gate_check": {
      "type": "string",
      "enum": [
        "PASS",
        "PASS_WITH_WARNINGS",
        "FAIL",
        "BLOCKED"
      ]
    },
    "deterministic_gate_status": {
      "type": "string",
      "enum": [
        "PASS",
        "PASS_WITH_WARNINGS",
        "FAIL",
        "BLOCKED"
      ]
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "recommendation": {
      "type": "string"
    }
  }
}
