{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ASF Automation Runner State",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "runner_state_version",
    "project",
    "step",
    "repo_path",
    "bridge_path",
    "current_state",
    "status",
    "allowed_states",
    "history",
    "open_blockers",
    "updated_at"
  ],
  "properties": {
    "runner_state_version": {
      "type": "string"
    },
    "project": {
      "type": "string"
    },
    "step": {
      "type": "string"
    },
    "repo_path": {
      "type": "string"
    },
    "bridge_path": {
      "type": "string"
    },
    "current_state": {
      "type": "string",
      "enum": [
        "PLANNED",
        "READY_FOR_CONTEXT",
        "CONTEXT_PACK_BUILT",
        "TASK_PACKET_BUILT",
        "WAITING_HUMAN_APPROVAL",
        "READY_FOR_CODEX",
        "CODEX_RUNNING",
        "CODEX_DONE",
        "REPORT_COLLECTED",
        "LOCAL_GATE_RUNNING",
        "LOCAL_GATE_PASS",
        "LOCAL_GATE_FAIL",
        "AI_REVIEW_RUNNING",
        "AI_REVIEW_PASS",
        "AI_REVIEW_FAIL",
        "REPAIR_PACKET_BUILT",
        "REPAIR_RUNNING",
        "READY_FOR_PUBLISH",
        "PUBLISH_RUNNING",
        "PUBLISHED",
        "CI_RUNNING",
        "CI_PASS",
        "CI_FAIL",
        "DONE",
        "BLOCKED",
        "ABORTED"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "PASS",
        "PASS_WITH_WARNINGS",
        "FAIL",
        "BLOCKED"
      ]
    },
    "allowed_states": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "PLANNED",
          "READY_FOR_CONTEXT",
          "CONTEXT_PACK_BUILT",
          "TASK_PACKET_BUILT",
          "WAITING_HUMAN_APPROVAL",
          "READY_FOR_CODEX",
          "CODEX_RUNNING",
          "CODEX_DONE",
          "REPORT_COLLECTED",
          "LOCAL_GATE_RUNNING",
          "LOCAL_GATE_PASS",
          "LOCAL_GATE_FAIL",
          "AI_REVIEW_RUNNING",
          "AI_REVIEW_PASS",
          "AI_REVIEW_FAIL",
          "REPAIR_PACKET_BUILT",
          "REPAIR_RUNNING",
          "READY_FOR_PUBLISH",
          "PUBLISH_RUNNING",
          "PUBLISHED",
          "CI_RUNNING",
          "CI_PASS",
          "CI_FAIL",
          "DONE",
          "BLOCKED",
          "ABORTED"
        ]
      }
    },
    "history": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "from_state",
          "to_state",
          "event",
          "status",
          "evidence"
        ],
        "properties": {
          "from_state": {
            "type": "string"
          },
          "to_state": {
            "type": "string"
          },
          "event": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "PASS",
              "PASS_WITH_WARNINGS",
              "FAIL",
              "BLOCKED"
            ]
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "open_blockers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "updated_at": {
      "type": "string"
    }
  }
}
