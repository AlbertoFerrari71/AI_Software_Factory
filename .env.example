# AI Software Factory — environment example
# Copy to .env for local development.
# Never commit real credentials.

ASF_ENV=local
ASF_LOG_LEVEL=INFO

# OpenAI API — future step, not used in STEP 020
OPENAI_API_KEY=

# GitHub API — future step, not used in STEP 020
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPOSITORY=

# Local storage — future step, not used in STEP 020
ASF_DATABASE_URL=sqlite:///./local_data/ai_software_factory.sqlite3

# Safety defaults
ASF_DEFAULT_APPROVAL_MODE=manual
ASF_ALLOW_DESTRUCTIVE_ACTIONS=false
